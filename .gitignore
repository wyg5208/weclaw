__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------
# 虚拟环境和 Conda
# ------------------------------------------
venv/
ENV/
env/
.venv

# ------------------------------------------
# PyInstaller
# ------------------------------------------
*.manifest
*.spec.backup
*.spec.old

# ------------------------------------------
# IDE 配置
# ------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ------------------------------------------
# 测试和覆盖率
# ------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
*.cover

# ------------------------------------------
# 临时文件和脚本
# ------------------------------------------
organize_root_files.py
*.tmp
*.bak
*.swp
*.swo
*~
*.log
temp/
*.db
*.db-journal

# ------------------------------------------
# 环境变量文件（包含敏感信息）
# ------------------------------------------
.env
.env.local

# ------------------------------------------
# 生成的资源文件
# ------------------------------------------
generated/*.png
generated/*.jpg
generated/*.jpeg
generated/*.gif
generated/*.webp
fairy_tales/
*.mp3
*.wav

# ------------------------------------------
