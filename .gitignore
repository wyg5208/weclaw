# ------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------
# 文档生成
# ------------------------------------------
*.mo
*.pot

# ------------------------------------------
# Node.js (如有)
# ------------------------------------------
node_modules/
package-lock.json

# ------------------------------------------
# 开发工具
# ------------------------------------------
.hatch/
.qoder/

# ------------------------------------------
# 文档（不纳入版本控制）
