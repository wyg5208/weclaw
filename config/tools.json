{
  "version": "1.0",
  "description": "Weclaw 工具配置 — 定义所有可用工具的元信息与行为参数",
  "onboarding_checklist": [
    "1. 创建 src/tools/{name}.py 继承 BaseTool",
    "2. 在本文件 tools 段添加工具配置（含 dependencies）",
    "3. 在 registry.py _build_init_kwargs 添加参数映射（如需特殊参数）",
    "4. 在 prompts.py INTENT_CATEGORIES 添加关键词到合适的意图",
    "5. 在 prompts.py INTENT_TOOL_MAPPING 添加工具到对应意图",
    "6. 在 prompts.py INTENT_PRIORITY_MAP 添加推荐/备选分组",
    "7. 在 tool_exposure.py _extract_tool_name 添加多下划线前缀（如适用）",
    "8. 在 tool_exposure.py CORE_TOOLS 或 EXTENDED_TOOLS 添加（如适用）",
    "9. 运行 python scripts/validate_tool_chain.py 确认全绿",
    "10. 运行 python tests/test_tool_optimization.py 确认测试通过"
  ],
  "tools": {
    "shell": {
      "enabled": true,
      "module": "src.tools.shell",
      "class": "ShellTool",
      "display": {
        "name": "命令行",
        "emoji": "💻",
        "description": "在 Windows 系统上执行 PowerShell 或 CMD 命令，获取命令输出结果",
        "category": "system"
      },
      "config": {
        "default_shell": "powershell",
        "timeout": 30,
        "max_output_length": 10000,
        "working_directory": "",
        "env_vars": {}
      },
      "security": {
        "risk_level": "high",
        "require_confirmation": false,
        "blacklist": [
          "format-volume", "format c:", "format d:", "format e:",
          "remove-item -recurse", "rm -rf", "del /s /q", "rd /s /q",
          "shutdown", "restart-computer", "stop-computer",
          "clear-disk", "diskpart", "reg delete",
          "new-service", "set-executionpolicy", "invoke-webrequest -outfile"
        ],
        "whitelist": [],
        "whitelist_mode": false
      },
      "actions": ["run"]
    },
    "file": {
      "enabled": true,
      "module": "src.tools.file",
