      "config": {
        "max_read_size": 1048576,
        "max_lines_per_page": 200,
        "allowed_dirs": [],
        "denied_dirs": ["C:\\Windows\\System32", "C:\\Program Files"],
        "allowed_extensions": [],
        "denied_extensions": [".exe", ".dll", ".sys", ".bat", ".cmd", ".ps1", ".vbs"]
