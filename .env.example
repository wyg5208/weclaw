# ==========================================
# WinClaw 环境变量配置模板
# ==========================================
# 复制此文件为 .env 并填入真实的 API Key
# 注意：.env 文件包含敏感信息，不应提交到 Git

# ------------------------------------------
# 安全密钥 (用于 JWT 认证)
# 生成命令：openssl rand -hex 32
# ------------------------------------------
SECRET_KEY=your_super_secret_key_change_this_immediately

# 测试令牌 (开发环境使用)
TEST_TOKEN=your_test_token_here

# Token 配置
ACCESS_TOKEN_EXPIRE_MINUTES=300    # 5 小时
TOKEN_REFRESH_THRESHOLD_MINUTES=60 # 1 小时

# JWT 设置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------
# 数据库配置 (可选，默认使用 SQLite)
# ------------------------------------------
# DATABASE_URL=sqlite:///./sql_app.db

# ------------------------------------------
# 阿里云 TTS (语音合成)
# ------------------------------------------
ALIYUN_APP_KEY=your_aliyun_app_key
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# ------------------------------------------
# 和风天气 API
# ------------------------------------------
QWEATHER_API_KEY=your_qweather_api_key
QWEATHER_API_HOST=nb7bygfnn5.re.qweatherapi.com

# ------------------------------------------
# AI 模型配置 (选择其中一个)
# ------------------------------------------

# DeepSeek AI 配置
AI_MODEL_TYPE=deepseek
OPENAI_API_KEY=sk-your_deepseek_api_key_here
AI_TEMPERATURE=0.5
# 注意：不要配置 OPENAI_BASE_URL，系统会自动使用正确的地址

# 智谱 GLM 配置（国内大模型）
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
GLM_IMAGE_MODEL=cogview-4-250304
GLM_VISION_MODEL=glm-4.5v

# Moonshot KIMI 配置（超长上下文）
# 获取地址：https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# 阿里云 QWEN 配置（通义千问）
# 获取地址：https://dashscope.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here
