# WinClaw 服务器环境配置
# 复制此文件为 .env 并修改配置

# ========== 管理员配置 ==========
# 管理员用户名（多个用逗号分隔）
ADMIN_USERNAMES=admin

# 管理员密码（格式：username:password，多个用逗号分隔）
# 示例单用户：admin:your_secure_password
# 示例多用户：admin:pass1,manager:pass2
ADMIN_PASSWORDS=admin:your_secure_password_here

# JWT 密钥（用于签发管理员 Token，建议使用长随机字符串）
ADMIN_SECRET_KEY=change_this_to_a_random_secret_key_in_production

# Token 过期时间（分钟）
ADMIN_TOKEN_EXPIRE_MINUTES=1440
